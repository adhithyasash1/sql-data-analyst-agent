OMLX_BASE_URL=http://127.0.0.1:8000/v1
OMLX_API_KEY=replace-me
TEXT_TO_SQL_MODEL=MLX-Qwopus3.5-9B-v3-4bit
SUMMARY_MODEL=MLX-Qwopus3.5-9B-v3-4bit
EMBEDDING_MODEL=mlx-community/Qwen3-Embedding-0.6B-4bit-DWQ
NORTHWIND_DB_PATH=data/northwind.db
METADATA_DB_PATH=data/metadata.db
RETRIEVAL_TOP_K=6
MAX_RESULT_ROWS=50
MAX_SQL_TOKENS=2048
MAX_SUMMARY_TOKENS=512
SQL_TEMPERATURE=0.0
SQL_TOP_P=1.0
SUMMARY_TEMPERATURE=0.2
SUMMARY_TOP_P=0.9
EMBEDDING_BATCH_SIZE=16
QUERY_TIMEOUT_MS=3000
MAX_REPAIR_ATTEMPTS=1
AUTO_REINDEX=true
ENABLE_LLM_SUMMARY=false
ENABLE_RESULT_SHAPE_CHECK=true
ENABLE_QUERY_LOGGING=true
REQUIRE_SQL_APPROVAL=false
